# ============================================================
# JBAFI - Variables de Producción
# ============================================================

# Base de Datos Principal (AFI)
POSTGRES_USER=afi_user
POSTGRES_PASSWORD=afi_pass
POSTGRES_DB=afiliaciones
DATABASE_URL=postgresql://afi_user:afi_pass@afi_postgres:5432/afiliaciones

# Base de Datos Compatibilidad (926)
CLONE_DB_USER=admin
CLONE_DB_PASSWORD=admin
CLONE_DB_NAME=migracion
CLONE_DATABASE_URL=postgresql://admin:admin@clone_full_postgres:5432/migracion

# Backend Principal
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# Vector Store (Qdrant)
QDRANT_URL=http://afi_qdrant:6333
QDRANT_API_KEY=

# Modelo LLM (Ollama)
OLLAMA_URL=http://afi_ollama:11434
MODEL_NAME=llama3.2:1b
EMBEDDING_MODEL=nomic-embed-text

# Frontend
VITE_API_URL=http://afi_backend:8000
NODE_ENV=production

# Sistema
ENVIRONMENT=production
DEBUG=false
